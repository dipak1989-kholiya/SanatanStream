rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: videos
    // Fields:
    //   - id: string (required)
    //   - title: string (required, max 200 chars)
    //   - description: string (required, max 1000 chars)
    //   - thumbnail: string (required, valid URL)
    //   - createdAt: timestamp (required)

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        request.auth.token.email == "dipak.kholiya@gmail.com";
    }

    function isValidVideo(data) {
      return data.keys().hasAll(['id', 'title', 'description', 'thumbnail', 'category', 'type', 'createdAt']) &&
             data.id is string && data.id.size() > 0 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 1000 &&
             data.thumbnail is string && data.thumbnail.matches("^https://.*") &&
             data.category is string && data.category.size() > 0 &&
             data.type in ['youtube', 'hls'] &&
             data.createdAt is timestamp;
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name']) && 
             data.name is string && data.name.size() > 0 && data.name.size() <= 50;
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['libraryTitle']) && 
             data.libraryTitle is string && data.libraryTitle.size() > 0 && data.libraryTitle.size() <= 50;
    }

    match /videos/{videoId} {
      allow read: if true;
      allow create: if isAdmin() && isValidVideo(request.resource.data);
      allow update: if isAdmin() && isValidVideo(request.resource.data);
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isAdmin() && isValidCategory(request.resource.data);
      allow update: if isAdmin() && isValidCategory(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create: if isAdmin() && isValidSettings(request.resource.data);
      allow update: if isAdmin() && isValidSettings(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
